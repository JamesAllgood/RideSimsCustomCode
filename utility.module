<?php

use Drupal\Core\Database\Database;
use Drupal\views\ViewExecutable;
use Drupal\Core\Block\BlockBase;

/**
 * Helper class to store view data using static variables instead of globals.
 * This replaces the deprecated global variable pattern for Drupal 11.2.0+
 * 
 * See REFACTORING_GUIDE.md for complete documentation on how to refactor
 * global variables to use this class.
 */
class ViewDataStorage {
    private static $storage = [];
    
    /**
     * Store data with a key.
     */
    public static function set($key, $value) {
        self::$storage[$key] = $value;
    }
    
    /**
     * Retrieve data by key.
     */
    public static function get($key, $default = null) {
        return self::$storage[$key] ?? $default;
    }
    
    /**
     * Check if a key exists.
     */
    public static function has($key) {
        return isset(self::$storage[$key]);
    }
    
    /**
     * Clear a specific key or all data.
     */
    public static function clear($key = null) {
        if ($key === null) {
            self::$storage = [];
        } else {
            unset(self::$storage[$key]);
        }
    }
    
    /**
     * Get all stored data (for debugging).
     */
    public static function getAll() {
        return self::$storage;
    }
}


/**
 * Implements hook_preprocess_views_view_field().
 */
 
//Logged in User Ride Sim Stats 
function utility_preprocess_views_view_field(&$variables) {

  	//Global Values 
	$view = $variables['view'];
	$field = $variables['field'];
	
	//Top 3 User Scores 
	if ($view->storage->id() == 'user_profile_stats' && $view->current_display == 'block_2' && $field->field == 'name') {
  	$uuid = \Drupal::currentUser()->id();
  	
  	
  	$con = \Drupal\Core\Database\Database::getConnection('default');
  	$query = $con->query('SELECT max(pd.score) score, pd.sim, pd.username '.
  					'from playerdata pd, '.
  					' `ex1i_node__field_ride_sim_id` si,'.
  					'`ex1i_node__field_beta_mode` b '. 
  					' where pd.sim = si.field_ride_sim_id_value AND si.entity_id=b.entity_id AND b.field_beta_mode_value=0 AND pd.username = :uuid group by pd.sim, username order by score DESC LIMIT 3', array(':uuid' => $uuid));
	$data = $query->fetchAll();
	$output="";
	foreach($data as $item) {
		$username = $item->username;
		$score = $item->score;
		$sim = $item->sim;
		$scoreformated = number_format($score);
		$output .= "<tr><td>".$scoreformated."</td><td>".lookupSimNumber($sim)."</td></tr>";
	}
	if ($output=="") $output.="No Scores Found For Current User.";
	else $output = "<table><tr></th></tr>".$output."</table>";
    $variables['output'] = $output;
    
    
	}
	
	//All Stats - Top Bar
  	if ($view->storage->id() == 'user_profile_stats' && $view->current_display == 'block_1' && $field->field == 'uid') {
  	$uuid = \Drupal::currentUser()->id();
  	$uuid =$variables['output'];
  	$con = \Drupal\Core\Database\Database::getConnection('default');
	$output="";

  //Total People
	$totalpple=0;
	$totaltime=0;
  	$query = $con->query('SELECT sum(pd.Challenge2) c1, sum(SimDuration) tm '.
  					'from playerdata pd, '.
  					' `ex1i_node__field_ride_sim_id` si,'.
  					'`ex1i_node__field_beta_mode` b '. 
  					' where pd.sim = si.field_ride_sim_id_value AND si.entity_id=b.entity_id AND b.field_beta_mode_value=0 AND pd.username = :uuid ', array(':uuid' => $uuid));
	$data = $query->fetchAll();
	foreach($data as $item) {
		$totalpple = $item->c1;
		//$totaltime = $item->tm;
		$hours = floor($item->tm/(60*60));
		$mins = date("i",$item->tm);
		$secs = date("s",$item->tm);
		$totaltime = $hours." hours ".$mins." mins ".$secs." seconds";
	}
	if ($totaltime=="") $totaltime=0;
	if ($totalpple=="") $totalpple=0;
	$totalpeopleformated = number_format($totalpple);

  //Total Challenges
 	$completedchallenges=0;
 	
 	
 	$query = $con->query(' select sid.field_ride_sim_id_value sim, v1.field_challenge_sql_value_1_value val1, v2.field_challenge_sql_value_2_target_id val2, v3.field_challenge_sql_value_3_value val3, v4.field_challenge_sql_value_4_target_id val4, v5.field_challenge_sql_value_5_target_id val5 '.
		' FROM '.
	 	' `ex1i_node__field_challenge_sql_value_1` v1, '.
	 	' `ex1i_node__field_challenge_sql_value_2` v2, '.
	 	' `ex1i_node__field_challenge_sql_value_3` v3, '.
	 	' `ex1i_node__field_challenge_sql_value_4` v4, '.
	 	' `ex1i_node__field_challenge_sql_value_5` v5, '.
	 	' `ex1i_node__field_based_upon_simulator` s, '.
	 	' `ex1i_node__field_ride_sim_id` sid, '.
 		' `ex1i_node__field_beta_mode` b '. 
 		' WHERE '.
 		' v1.entity_id = v2.entity_id '.
 		' AND v1.entity_id = v3.entity_id '.
 		' AND v1.entity_id = v4.entity_id '.
 		' AND v1.entity_id = v5.entity_id '.
 		' AND v1.entity_id = s.entity_id '.
 		' AND b.entity_id = s.field_based_upon_simulator_target_id '.
 		' AND b.entity_id = sid.entity_id '.
 		' AND b.field_beta_mode_value=0 ' 
 		); 	
 	$data = $query->fetchAll();
 	$allmedals=0;
 	foreach($data as $item) {
		$v1=$item->val1;
		$v2=$item->val2;
		$v3=$item->val3;
		$v4=$item->val4;
		$v5=$item->val5;
		$sim = $item->sim;
		$parts=array($v1,$v2,$v3,$v4,"","",$v5);
		$allmedals++;
		if (checkChallengeCompleted($con,$uuid,$sim,$parts))$completedchallenges++;
 	}
	
	  //mostplayedsim
	$mostplayedsim = 'None Played';
	$mostplayedsimtime = 0;
  	$query = $con->query('SELECT sum(SimDuration) tm, sim '.
  					'from playerdata pd, '.
  					' `ex1i_node__field_ride_sim_id` si,'.
  					'`ex1i_node__field_beta_mode` b '. 
  					' where pd.sim = si.field_ride_sim_id_value AND si.entity_id=b.entity_id AND b.field_beta_mode_value=0 AND pd.username = :uuid group by sim order by tm DESC LIMIT 1', array(':uuid' => $uuid));
	$data = $query->fetchAll();
	foreach($data as $item) {
		$mostplayedsim = lookupSimNumber($item->sim);
		$mostplayedsimtime = $item->tm;
	}
	
 	$output .= "<div class='TotalUserStats'><p class='Title'>Total Sim Hours Logged </p><p class='Value'>".$totaltime."</p></div>";
 	$output .= "<div class='TotalUserStats'><p class='Title'>Total Sim Peeps Handled </p><p class='Value'>".$totalpeopleformated."</p></div>";
 	$output .= "<div class='TotalUserStats'><p class='Title'>Total Challenges Completed </p><p class='Value'>".$completedchallenges." Out Of ".$allmedals."</p></div>";
 	
 	//Update Challenges Complete Table
 	//updateChallengesCompletedTable($uuid,$completedchallenges);
 	
 	
 	$output .= "<div class='TotalUserStats'><p class='Title'>Most Played Sim </p><p class='Value'>".$mostplayedsim."</p></div>";    
    
