margin-right: 0;
text-align: center;
height: 35px;
background: white;
overflow: hidden;
border: 0;
color: black;
-moz-appearance: none;
-webkit-appearance: none;
appearance: none;
cursor: pointer; 
}

.ChallengeFlex .SimsInfo1 {
  width: 100%;
}


.ChallengeFlex {
display: flex;
flex-wrap: wrap;
}

#MedalsMain {
  display: flex;
  flex-wrap: wrap;
}

#MedalsStack {
  width: 10%;
  border-style: solid;
  border-width: 1px;
  border-color: #d7f4fe;
}

ul.FriendsListMainNew {
overflow: auto;
white-space: nowrap !important;
height: 150px;
display: inline-block !important;
width: 100%;
margin-top: 10px !important;
}


.FriendsListNew {
  vertical-align: top;
  display: inline-block;
}

.friendsbox2 {
  width: 170px !important;
  padding-top: 25px;
}

#friendsboximage {
  width: 100px;
  height: 100px;
}

#UserSearchBox {
  height: 45px;
  overflow: hidden;
  border: 0;
  text-align: center;
  color: black;
  width: calc(95% - 45px) !important;
  border-top-left-radius: 40px;
  border-bottom-left-radius: 40px;
  margin: 0;
}

#UserSearchForm {
  display: flex;
  justify-content: center;
}	

#UserSearchButton {
  overflow: visible;
  position: relative;
  border: 0;
  padding: 0;
  cursor: pointer;
  height: 45px;
  width: 45px;
  font: bold 15px/40px 'lucida sans', 'trebuchet MS', 'Tahoma';
  color: white;
  text-transform: uppercase;
  background: #183569;
  border-radius: 0 3px 3px 0;
  text-shadow: 0 -1px 0 rgba(0, 0 ,0, .3);
  border-bottom-right-radius: 40px;
  border-top-right-radius: 40px;
}

#SearchForFriendsDiv {
  display: flex;
  margin: 0;
}

.MainChallengeSection {
  width: 90%;
  margin-left: 5%;
  margin-right: 5%;
  margin-top: 20px;
}

.TimeSection {
width: 50%;
}

.ValueSection {
width: 50%;
}


/* Scroll Bar CSS */
.FriendsListMainNew::-webkit-scrollbar {
  	width: 5px;
}
.FriendsListMainNew::-webkit-scrollbar-track {
	background: #a5d9ec; 
}
.FriendsListMainNew::-webkit-scrollbar-thumb {
	background: #0e4f74; 
}


#ChallengeSwitch {
width: 100%;
padding-top: 8px;
}

.switch {
  position: relative;
  display: inline-block;
  width: 60px;
  height: 34px;
}

.switch input { 
  opacity: 0;
  width: 0;
  height: 0;
}

.slider {
  position: absolute;
  cursor: pointer;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #ccc;
  -webkit-transition: .4s;
  transition: .4s;
}

.slider:before {
  position: absolute;
  content: '';
  height: 26px;
  width: 26px;
  left: 4px;
  bottom: 4px;
  background-color: white;
  -webkit-transition: .4s;
  transition: .4s;
}

input:checked + .slider {
  background-color: #2196F3;
}

input:focus + .slider {
  box-shadow: 0 0 1px #2196F3;
}

input:checked + .slider:before {
  -webkit-transform: translateX(26px);
  -ms-transform: translateX(26px);
  transform: translateX(26px);
}

.slider.round {
  border-radius: 34px;
}

.slider.round:before {
  border-radius: 50%;
}

/* Mobile CSS Changes Code */
@media only screen and (max-width: 768px) {


.Challenge3 {
width: 100% !important;
margin-right: 0 !important;
}

.Challenge4 {
width: 100% !important;
}

.Challenge5 {
width: 100% !important;
}

.Challenge {
width: 50% !important;
}

.Challenge2 {
width: 100% !important;
}

}





