}

}


		</style>";
		
		$output .= "<a href='/blog/".trim($parts[2])."'>";
		$output .= "<img src='" .trim($parts[1])."' alt='".trim($parts[4])."'>";
		$output .= "<PlusPageTitle>".trim($parts[4])."</PlusPageTitle>";
		$output .= "<PlusPageArticle>".strip_tags(trim($parts[0]))."</PlusPageArticle>";
		$output .= "</a>";
		
// 		{{ field_news_content }} |^
// {{ field_news_image }} |^
// {{ field_news_url_ }} |^
// {{ field_publish_date }} |^
// {{ field_news_title }}
	
    $variables['output'] = $output;    	
	}	



	//2024 plus page - medals	
	if ($view->storage->id() == '2024_ride_sims_plus' && $view->current_display == 'block_4' && $field->field == 'field_ride_sim') {
	
	$output = "";	
	
	//find user information about user
    $uid = \Drupal::currentUser()->id();
    $user = \Drupal\user\Entity\User::load($uid);
    
	$output.= "<div class='PlusPageData'>";

	//all challenge medals someones got 
    $output.= "<MainBlockHeading class='BannerPink'>My Challenge Medals</MainBlockHeading>";	  
 	
 	$completedchallenges=0;
 	
 	$output.= "<div class='MedalsPlusPage'>";
 	
 	$con = \Drupal\Core\Database\Database::getConnection('default');
 	$query = $con->query(' select sid.field_ride_sim_id_value sim, v1.field_challenge_sql_value_1_value val1, v2.field_challenge_sql_value_2_target_id val2, v3.field_challenge_sql_value_3_value val3, v4.field_challenge_sql_value_4_target_id val4, v5.field_challenge_sql_value_5_target_id val5, v6.field_challenge_medal_target_id medal'.
		' FROM '.
	 	' `ex1i_node__field_challenge_sql_value_1` v1, '.
	 	' `ex1i_node__field_challenge_sql_value_2` v2, '.
	 	' `ex1i_node__field_challenge_sql_value_3` v3, '.
	 	' `ex1i_node__field_challenge_sql_value_4` v4, '.
	 	' `ex1i_node__field_challenge_sql_value_5` v5, '.
	 	' `ex1i_node__field_challenge_medal` v6, '.
	 	' `ex1i_node__field_based_upon_simulator` s, '.
	 	' `ex1i_node__field_ride_sim_id` sid, '.
 		' `ex1i_node__field_beta_mode` b '. 
 		' WHERE '.
 		' v1.entity_id = v2.entity_id '.
 		' AND v1.entity_id = v3.entity_id '.
 		' AND v1.entity_id = v4.entity_id '.
 		' AND v1.entity_id = v5.entity_id '.
 		' AND v1.entity_id = v6.entity_id '.
 		' AND v1.entity_id = s.entity_id '.
 		' AND b.entity_id = s.field_based_upon_simulator_target_id '.
 		' AND b.entity_id = sid.entity_id '.
 		' AND b.field_beta_mode_value=0 ' 
 		); 	
 	$data = $query->fetchAll();
 	$allmedals=0;
 	foreach($data as $item) {
		$v1=$item->val1;
		$v2=$item->val2;
		$v3=$item->val3;
		$v4=$item->val4;
		$v5=$item->val5;
		$medal=$item->medal;
		$sim = $item->sim;
		$parts=array($v1,$v2,$v3,$v4,"","",$v5);
		$allmedals++;
		
		//temp fix
		$uuid = $uid;
		
		$MedalsEarnt=getMedalPhotoFromID(checkChallengeCompletedRideSimsPlus($con,$uuid,$sim,$parts,$medal));
		
		if (!$MedalsEarnt){
		}else{
			$output.="<div class='MedalItem'><img class='MedalPhoto' src='"."https://ridesims.com/".$MedalsEarnt."'></div>";
		}
 	}

	$output.="</div>";
	
    $variables['output'] = $output;    	
	}	













//End of global funcation	
}



//AKV
function akv($array, $key, $notempty=false, $default=''){ 
	    if (is_array($array) && array_key_exists($key, $array) && ($notempty || (($array[$key] !== '') && ($array[$key] !== null)))) return $array[$key];

        return $default;
    }
    
function RideSimsWrappedSystem($txt1,$txt2hours,$txt2mins, $txt3sim, $txt4, $txt5, $uid){
  
// (A) OPEN IMAGE
