  						' `ex1i_node__field_ride_sim_promo_large` frsp,'.
  						' `ex1i_file_managed` efm, '.
  						' `ex1i_node__field_url_name` enfun '.
  						'  where frs.entity_id = frsp.entity_id '.
  						'  and frs.entity_id = enfun.entity_id '.
  						'  and frsp.field_ride_sim_promo_large_target_id = efm.fid'.
  						'  and frs.field_ride_sim_value = :data limit 1', array("data"=>$number));
	$file='';
	$data = $query->fetchAll();

	foreach($data as $item) {
		//file_put_contents("/kunden/homepages/34/d764919300/htdocs/www_ridesims_com_v3_composer/jameswible123456789.log",date("r").$item->img."\r\n", FILE_APPEND);

		$file = str_replace('public:/','/sites/default/files/', $item->img);
	}
	
			//file_put_contents("/kunden/homepages/34/d764919300/htdocs/www_ridesims_com_v3_composer/jameswible123456789.log",date("r").$file."\r\n", FILE_APPEND);
	
	return ($file);
}

