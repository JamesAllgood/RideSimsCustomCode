  	$con = \Drupal\Core\Database\Database::getConnection('default');
  	$query = $con->query('SELECT username uid, sum(Challenge2)/(sum(SimDuration)/3600) score '.
  			' FROM playerdata '.
  			' where sim = :simid '.
  			' group by username order by score DESC ', array(':simid' => $globalsimid));
	$data = $query->fetchAll();
	$output="";
	$counter= 1;
	$foundme=false;
	foreach($data as $item) {
		if (($counter<6) || ($item->uid == $loggedin_uid)){
			$uname = lookupUserNumber($item->uid);
			$score = $item->score;
			$scoreformatted = number_format($score);
			$output .= "<tr ".($item->uid == $loggedin_uid?' class="myscore" ':'')."><td>$counter</td><td><a href='/user/".$uname."'>".$uname."</a></td><td>".($scoreformatted)."</td></tr>";
			if ($item->uid == $loggedin_uid) $foundme=true;
		}
		if (($counter>5) && $foundme) break;
		$counter++;

	}
	if ($output=="") $output = "No one has played this simulator yet.";
	else $output = "<table><tr></th></tr>".$output."</table>";
    $variables['output'] = $output;
	}	
	
  	//Get Ride Sims Medals From Database - Public Sims
  	if ($view->storage->id() == 'ride_sim_player_view' && $view->current_display == 'page_1' && $field->field == 'field_ride_sim_difficulty_') {
