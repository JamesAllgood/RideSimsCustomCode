// sort associative arrays
function sortArrayOfAsociativeArraysOnKey($array,$sortkey){
        $ind = array();
        foreach ($array as $key => $row){
            $ind[$key] = akv($row,$sortkey);
        }
        array_multisort($ind, SORT_ASC, $array);

        return($array);
}

//check users roles
function checkUsersRoles($userid){
	$con = \Drupal\Core\Database\Database::getConnection('default');
 
 	$query = $con->query("SELECT `roles_target_id` FROM `ex1i_user__roles` where `entity_id` = :uuid", array("uuid"=>$userid));

	$data = $query->fetchAll();
	$name='';
	foreach($data as $item) {
		$name.=$item->roles_target_id;
		$name.=" $$ ";
	}
	return ($name);
}

//Set View Titles
function utility_views_pre_render(ViewExecutable $view) {

	//Ride Sims Public Display
	if ($view->id() == 'ride_sim_player_view' && $view->current_display == 'page_1') {

   		$path = \Drupal::request()->getpathInfo();
   		$arg  = explode('/',$path);

		if ($arg['1'] == 'ride-simulators') {
   			$title = $arg['2'];
   			if ($title) {
   				$title = preg_replace("/[-]/", " ", $title);
	  			$specialtoken = $title.' ';
			    $view->setTitle($specialtoken);
			    // Set the view title.
   			}
		}
    }
    
	//Ride Sims Beta Display
	if ($view->id() == 'ride_sim_player_view' && $view->current_display == 'page_2') {

   		$path = \Drupal::request()->getpathInfo();
   		$arg  = explode('/',$path);

		if ($arg['1'] == 'ride-simulators' && $arg['2'] == 'beta' ) {
   			$title = $arg['3'];
   			if ($title) {
   				$title = preg_replace("/[-]/", " ", $title);
	  			$specialtoken = $title.' ';
			    $view->setTitle($specialtoken);
			    // Set the view title.
   			}
		}
    }
 
 	//Home Page News Display
	if ($view->id() == 'home_page_news_display' && $view->current_display == 'page_1') {

   		$path = \Drupal::request()->getpathInfo();
   		$arg  = explode('/',$path);

		if ($arg['1'] == 'news' ) {
   			$title = $arg['2'];
   			if ($title) {
   				$title = preg_replace("/[-]/", " ", $title);
	  			$specialtoken = $title.' ';
			    $view->setTitle($specialtoken);
			    // Set the view title.
   			}
		}
    }
 
  	//Ride Sims Plus Blog Display
	if ($view->id() == 'news_article_display' && $view->current_display == 'page_1') {

   		$path = \Drupal::request()->getpathInfo();
   		$arg  = explode('/',$path);

		if ($arg['1'] == 'blog' ) {
   			$title = $arg['2'];
   			if ($title) {
   				$title = preg_replace("/[-]/", " ", $title);
	  			$specialtoken = $title.' ';
			    $view->setTitle($specialtoken);
			    // Set the view title.
   			}
		}
    }
    
      	//Ride Sims Plus Blog Display
	if ($view->id() == '2024_ride_sims_plus' && $view->current_display == 'page_1') {

   		$path = \Drupal::request()->getpathInfo();
   		$arg  = explode('/',$path);

		if ($arg['1'] == 'ride-sims-plus' ) {
			    $view->setTitle("Ride Sims Plus Blog");
		}
    }
    
    
    //Ride Sims Plus Blog Display
	if ($view->id() == 'ride_sims_view_2024' && $view->current_display == 'page_1') {

   		$path = \Drupal::request()->getpathInfo();
   		$arg  = explode('/',$path);

		if ($arg['1'] == 'simulators' ) {
			    $view->setTitle("Ride Sims Simulators");
		}
    }
     
}
