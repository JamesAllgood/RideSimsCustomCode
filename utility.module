$message = explode(' ', $sim);

if (strlen($sim) > 15) {
   
$txt3part1 = $message[0]." ". $message[1]; 
$txt3part2 = $message[2];

}else{
$txt3part1 = $sim;
$txt3part2 = "";
}

$txt4 = $txt4;

$txt5 = $txt5;

