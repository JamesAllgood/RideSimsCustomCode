   	$con = \Drupal\Core\Database\Database::getConnection('default');
   	$query = $con->query('SELECT  count(*) played, pd.sim, u.field_url_name_value url '.
   					'from playerdata pd, '.
   					' `ex1i_node__field_url_name` u, '.
   					' `ex1i_node__field_ride_sim_id` si,'.
   					' `ex1i_node__field_beta_mode` b, '. 
   					' `ex1i_node__field_patreon_beta_mode` p '.
   					' where pd.sim = si.field_ride_sim_id_value '.
   					' AND si.entity_id=b.entity_id '.
   					' AND b.field_beta_mode_value=0 '.
   					' AND si.entity_id = u.entity_id '.
   					' AND si.entity_id = p.entity_id '.
   					' AND p.field_patreon_beta_mode_value=0 '.
   					' group by sim,url order by played DESC LIMIT 5', array());
 	$data = $query->fetchAll();
 	$output="";
