	//Sim Log 3 Code 
  	if($view->storage->id() == 'sim_log_3' && $view->current_display == 'block_1' && $field->field == 'field_ride_sim') {
	$uuid = \Drupal::currentUser()->id();
  	$con = \Drupal\Core\Database\Database::getConnection('default');
	$extrasql = "";
  	$output="";
  	$query = $con->query('SELECT frs.`field_ride_sim_value` name, efm.`uri` img, fstt.field_sim_top_tips_value descr '.
  						' FROM `ex1i_node__field_ride_sim` frs, '.
  						' `ex1i_node__field_ride_sim_promo_` frsp,'.
  						' `ex1i_file_managed` efm, '.
  						' `ex1i_node__field_sim_top_tips` fstt where fstt.entity_id=frs.entity_id AND frs.entity_id = frsp.entity_id and frsp.field_ride_sim_promo__target_id = efm.fid', array());
	$data = $query->fetchAll();

	$found=false;
	
	foreach($data as $item) {
		$simname = preg_replace("/[^A-Za-z0-9]/", '', $item->name);
		$output .="<div class='siminfo simname_".$simname."'>";
		$output .="<img src='".str_replace('public:/','/sites/default/files/', $item->img)."' >";
		$output .="<div class='simdescr'> ".$item->descr."</div>";
		$output .="</div>";
		
	}
	$variables['output'] = $output;
}

	//Sim Log 4 Code
  	if($view->storage->id() == 'sim_log_4' && $view->current_display == 'block_1' && $field->field == 'field_ride_sim') {
	$uuid = \Drupal::currentUser()->id();
  	$con = \Drupal\Core\Database\Database::getConnection('default');
	$extrasql = "";
  	$output="";
	//SimDuration = Time, Challenge2 = People, Score = Score
  	$querysim = $con->query('SELECT a.`field_ride_sim_value` simname, b.`field_ride_sim_id_value` simnumber FROM `ex1i_node__field_ride_sim` a, `ex1i_node__field_ride_sim_id` b where a.entity_id = b.entity_id', array());
	$datasim = $querysim->fetchAll();
	foreach($datasim as $itemsim) {
  		$sim_id = $itemsim->simnumber;
	  	$query = $con->query('SELECT sim simnumber, MAX (score) maxscore, MAX(Challenge2) maxppl, SUM(SimDuration) playtime, sum(Challenge2) people, sum(Score) score FROM `playerdata` where `username`= :uuid AND sim = :sim group by sim', array(":uuid"=>$uuid, ":sim"=>$sim_id));
		$data = $query->fetchAll();

		$simname = preg_replace("/[^A-Za-z0-9]/", '', $itemsim->simname);
		$ppl=0;
		$maxppl=0;
		$time=0;
		$throughput=0;
		$score=0;
		$maxscore=0;
	
		foreach($data as $item) {
			$found=true;
			$ppl = $item->people;
			$hours = floor($item->playtime/(60*60));
			$mins = date("i",$item->playtime);
			$secs = date("s",$item->playtime);
			$time = $hours." hours ".$mins." mins ".$secs." seconds";
			$throughput = floor(floatVal($item->people)/(floatVal($item->playtime)/3600)); 
			$score=$item->score;
			$maxppl = $item->maxppl;
			$maxscore=$item->maxscore;
		}
		
		$throughputformatted = number_format($throughput);
		$peopleformatted = number_format($ppl);
		$scoreformatted = number_format($score);
		$maxpplformatted = number_format($maxppl);
		$maxscoreformatted = number_format($maxscore);
		
		
		$output .="<div class='simstats simname_".$simname."'>";
		$output .="<div class='stat'><div class='title'>Peeps Handled (Highest Session / Total)</div><div class='value'>".($maxpplformatted!=$peopleformatted?$maxpplformatted." / ":"").$peopleformatted."</div></div>";
		$output .="<div class='stat'><div class='title'>Time Played</div><div class='value'>".$time."</div></div>";
		$output .="<div class='stat'><div class='title'>Throughput (pph)</div><div class='value'>".$throughputformatted."</div></div>";
		$output .="<div class='stat'><div class='title'>Score (Highest Session / Total)</div><div class='value'>".($maxscoreformatted!=$scoreformatted?$maxscoreformatted." / ":"").$scoreformatted."</div></div>";
		$output .="</div>";
	}
	$variables['output'] = $output;

}

	//Stats - Scores
  	if($view->storage->id() == 'latest_scores' && $view->current_display == 'block_1' && $field->field == 'field_ride_sim'){
  	// defaults to Local London time
  	
  	
function UTCDateToTimezone($dateTimeUTC = null, $timeZone = 'Europe/London', $dateFormat = 'Y-m-d H:i:s'){
        $dateTimeUTC = $dateTimeUTC ? $dateTimeUTC : date("Y-m-d H:i:s");

        $date = new DateTime($dateTimeUTC, new DateTimeZone('UTC'));
        $date->setTimeZone(new DateTimeZone($timeZone));

        return $date->format($dateFormat);
}

  	
   	$con = \Drupal\Core\Database\Database::getConnection('default');
   	$query = $con->query('SELECT pd.score, pd.sim, pd.username, DATE_FORMAT(pd.DateTime,'."'".'%d-%m-%Y %k:%i'."'".') dt, pd.DateTime , u.field_url_name_value url '.
   					'from playerdata pd, '.
   					' `ex1i_node__field_url_name` u, '.
   					' `ex1i_node__field_ride_sim_id` si,'.
   					' `ex1i_node__field_patreon_beta_mode` p, '.
   					' `ex1i_node__field_beta_mode` b '. 
   					' where pd.sim = si.field_ride_sim_id_value '.
   					' AND si.entity_id=b.entity_id '.
   					' AND b.field_beta_mode_value=0 '.
   					' AND si.entity_id = u.entity_id '.
   					' AND si.entity_id = p.entity_id '.
   					' AND p.field_patreon_beta_mode_value=0 '.
   					' order by DateTime DESC LIMIT 5', array());
 	$data = $query->fetchAll();
 	$output="";
 	foreach($data as $item) {
 		$username = $item->username;
 		$uname=lookupUserNumber($username);
 		$score = $item->score;
 		$simurl = $item->url;
 		$sim = $item->sim;
		$when = UTCDateToTimezone($item->dt,'Europe/London','Y-m-d H:i');	

		$simname = lookupSimNumber($sim);
		$scoreformated = number_format($score);
		$output .= "<tr><td>".$when."</td><td><a href='/user/".$uname."'>".$uname."</a></td><td><a href='/ride-simulators/".$simurl."'>".$simname."</a></td><td>".$scoreformated."</td></tr>";
 	}
 	if ($output=="") $output.="Nothing found.";
 	else $output = "<table><tr></th></tr>".$output."</table>";
    $variables['output'] = $output;
  	//$variables['output'] = "wibble world";
  	
  	
  	}

	//Stats - Sims
