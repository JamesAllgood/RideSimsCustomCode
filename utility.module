//User Badges System - fixed - 9-02-25
if($view->storage->id() == 'user_badges' && $view->current_display == 'block_1' && $field->field == 'field_job_role_or_date') {
    $uuid = \Drupal::currentUser()->id();
    // Retrieve user roles from ViewDataStorage
    $userroles = ViewDataStorage::get('userroles', '');
    if (empty($userroles)) {
        // Fetch user roles directly from database if not stored
        $user_entity = \Drupal\user\Entity\User::load($uuid);
        if ($user_entity) {
            $roles = $user_entity->getRoles();
            $role_labels = [];
            foreach ($roles as $role_name) {
                $role = \Drupal\user\Entity\Role::load($role_name);
                if ($role) {
                    $role_labels[] = $role->label();
                }
            }
            $userroles = implode('|', $role_labels);
        } else {
            $userroles = '';
        }
    }
    static $dispcounter = 0;
    static $foundabadge = false;
    static $medalcount = 0;

    // Early return for empty UUID with hide script
    if ($uuid == '') {
        $variables['output'] = '<script>
            setTimeout(function() {
                const elementsToHide = [
                    "block-views-block-user-badges-block-1",
                    "block-usermedalstitle",
                    "block-simlogtitle",
                    "block-views-block-sim-log-2-block-1",
                    "block-views-block-sim-log-3-block-1",
                    "block-views-block-sim-log-4-block-1",
                    "block-views-block-user-challenges-block-1"
                ];
                elementsToHide.forEach(id => {
                    const element = document.getElementById(id);
                    if (element) element.style.display = "none";
                });
            }, 1);
        </script>';
        return;
    }

    try {
        $con = \Drupal\Core\Database\Database::getConnection('default');
        
        // Get medal count if first run
        if ($dispcounter == 0) {
            try {
                $query = $con->query('SELECT count(*) medals FROM `ex1i_node__field_badge_name`');
                $result = $query->fetchAll();
                $medalcount = !empty($result) ? $result[0]->medals : 0;
            } catch (\Exception $e) {
                // Silently continue if medal count query fails
                $medalcount = 0;
            }
        }

        $badge = $variables['output'];
        $badgearray = explode("|", $badge);
        
        // Parse conditions
        $conds = explode("@", trim($badgearray[1]));
        $when = str_replace("&amp;", "&", trim($conds[0]));
        $whens = explode("&", $when);
        
        // Build query parameters
        $params = [':uuid' => $uuid];
        $extrasql = "";
        
        if (count($whens) == 2) {
            $extrasql = " and date(`DateTime`) BETWEEN :when AND :when2 ";
            $params[':when'] = trim($whens[0]);
            $params[':when2'] = trim($whens[1]);
        } else {
            $extrasql = " and date(`DateTime`) = :when ";
            $params[':when'] = $when;
        }

        // Check user data
        $found = false;
        try {
            $query = $con->query('SELECT `username` FROM `playerdata` WHERE `username` = :uuid ' . $extrasql, $params);
            $data = $query->fetchAll();
            $found = !empty($data);
        } catch (\Exception $e) {
            // Skip if query fails
            $found = false;
        }

        // Check challenge completion
        $completed = true;
        for ($c = 1; $c < count($conds) && $completed; $c++) {
            $segments = explode("&", $conds[$c]);
            if (count($segments) >= 2) {
                $simbits = explode("=", $segments[0]);
                $scorebits = explode("=", $segments[1]);
                
                if (isset($simbits[1]) && isset($scorebits[1])) {
                    $parts = [
                        trim($scorebits[1]),
                        "score",
                        trim($simbits[1]),
                        "sim",
                        '',
                        ''
                    ];
                    
                    try {
                        if (!checkChallengeCompleted($con, $uuid, '', $parts)) {
                            $completed = false;
                        }
                    } catch (\Exception $e) {
                        $completed = false;
                    }
                }
            }
        }

        // Generate output
        if ($found && $completed) {
            $formattedoutput = "<div class='userbadgeicon'>{$badgearray[2]}<div class='title'>{$badgearray[0]}</div></div>";
            $variables['output'] = $formattedoutput;
            $foundabadge = true;
        } else {
            $explodeduserroles = explode("|", $userroles);
            if (in_array(trim($badgearray[1]), $explodeduserroles) && $completed) {
                $formattedoutput = "<div class='userbadgeicon'>{$badgearray[2]}<div class='title'>{$badgearray[0]}</div></div>";
                $variables['output'] = $formattedoutput;
                $foundabadge = true;
            } else {
                $variables['output'] = '';
            }
        }

        $dispcounter++;
        
        // Show "No badges" message if needed
        if (($dispcounter == $medalcount) && (!$foundabadge)) {
            $variables['output'] = '<div class="NoBadgesFound">No badges unlocked yet. Check back soon!</div>';
        }

    } catch (\Exception $e) {
        // If main try block fails, ensure empty output
        $variables['output'] = '';
    }
}



	//Challenge system code - get live sims from database
  	if($view->storage->id() == 'user_challenges' && $view->current_display == 'block_1' && $field->field == 'field_challenge_sql_value_1') {
	$uuid = \Drupal::currentUser()->id();
  	$sqlchallenge =$variables['output'];

  	$con = \Drupal\Core\Database\Database::getConnection('default');
	$extrasql = "";
  	$output="";
  	
 	$parts = explode("|",$sqlchallenge);

    $sim = $parts[7];
    $sim = html_entity_decode($sim, ENT_QUOTES); 
	$sim=preg_replace("/[^A-Za-z0-9]/", '', $sim);

	if (checkChallengeCompleted($con,$uuid,$sim,$parts)) $output .= $parts[4];
	else $output .= $parts[5];
    
    $title = $parts[8];
    
    $formattedoutput = "<div class='simbadgeicon simname_".$sim."' title='".str_replace("'","`",strip_tags($parts[9]))."'>".$output."<div class='title'>".$title."</div></div>";
    	
    $variables['output'] = $formattedoutput;
	}

	//Sim Log 2 Code
  	if($view->storage->id() == 'sim_log_2' && $view->current_display == 'block_1' && $field->field == 'field_ride_sim') {
	$uuid = \Drupal::currentUser()->id();
  	$con = \Drupal\Core\Database\Database::getConnection('default');
	$extrasql = "";
  	$output="";
  	$query = $con->query(' SELECT rs.`field_ride_sim_value` '.
  						' FROM `ex1i_node__field_ride_sim` rs, '.
  						' `ex1i_node__field_beta_mode` b, '.
  						' `ex1i_node__field_patreon_beta_mode` p '.
  						' WHERE rs.entity_id = b.entity_id '.
  						' AND b.field_beta_mode_value = 0 '.
  						' AND rs.entity_id = p.entity_id '.
   						' AND p.field_patreon_beta_mode_value=0 '.
  						' ORDER by `field_ride_sim_value` ASC', array());
	$data = $query->fetchAll();

	$found=false;
	$output.='<script>function handleRideSimNameClick(sim){ ';
//	$output .=" console.log('in',sim); ";
	$output .='nodes =  document.getElementsByClassName("shownsimbadges");';
	$output .= 'while (nodes.length>0){ ';
	$output .= ' nodes[0].className = nodes[0].className.replace(/\bshownsimbadges\b/g, "");;';
	$output .= '}'; 

	$output .='var nodes2 =  document.getElementsByClassName("simname_"+sim);';
	$output .= 'for (var i=0; i<nodes2.length; i++){ ';
	$output .= ' nodes2[i].classList.add("shownsimbadges");';
	$output .= '}';
	
	$output .='nodes =  document.getElementsByClassName("shownsimselector");';
	$output .= 'while (nodes.length>0){ ';
	$output .= '  nodes[0].className = nodes[0].className.replace(/\bshownsimselector\b/g, "");;';
	$output .= '}'; 
	$output .='var nodes2 =  document.getElementById("simselector_"+sim);';
	$output .= 'nodes2.classList.add("shownsimselector");';
	
	$output .='}</script>';
	
	$output .= "<ul class='sim_list'>";
	$first='';
	foreach($data as $item) {
		$simname = preg_replace("/[^A-Za-z0-9]/", '', $item->field_ride_sim_value);
		$output.="<li class='simselector' id='simselector_".$simname."' onclick='handleRideSimNameClick(\"".$simname."\");'>".$item->field_ride_sim_value."</li>";
		if ($first=="") $first=$simname;
	}
	$output.= "</ul>";
	if ($uuid!="") {
	$output.="<script>setTimeout(function(){handleRideSimNameClick('".$first."');}, 1000);</script>";
