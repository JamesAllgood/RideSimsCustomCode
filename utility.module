function getMedalPhotoFromID($number){
	$con = \Drupal\Core\Database\Database::getConnection('default');
	$query = $con->query('SELECT `uri` FROM `ex1i_file_managed` where `fid` =:plid', array(':plid'=>$number));
	$file='';
	$data = $query->fetchAll();
	foreach($data as $item) {
		$file = str_replace('public:/','/sites/default/files/', $item->uri);
	}
	
	return ($file);
}      
      
function checkChallengeCompletedAndSavePhoto($con,$uuid,$sim,$parts){

	$params=array(':uuid' => $uuid);
	$extrasql = "";
	if (!is_array($parts)) $parts=array();
	$parts= array_pad($parts,8,'');
  	  	  	
	$parts[3] = str_replace("\n", "", $parts[3]);
	$parts[3] = str_replace("\r", "", $parts[3]);
	if ((trim($parts[3])=="sim")||(trim($parts[3])==6)){
		if (trim($parts[2])!=""){
			$extrasql .= " and `sim` = :sim " ;
			$params[':sim']= trim($parts[2]);		
		}
	}

	$parts[6] = str_replace("\n", "", $parts[6]);
	$parts[6] = str_replace("\r", "", $parts[6]);
	switch(trim($parts[6])){
		case "total":
		case "16":
			$fldpre="group by `username` having sum(";
			$fldpost=") ";
		break;
		default:
			$fldpre=' and ';
			$fldpost='';
		break;
	}
	//$output.=print_r($parts,true);
	switch(trim($parts[1])){
		case "score":
		case "5":
			$extrasql .= " ".$fldpre."`score`".$fldpost." >= :score " ;
			$params[':score']= trim($parts[0]);
		break;
		case "Challenge1":
		case "10":
			$extrasql .= " ".$fldpre."`Challenge1`".$fldpost." >= :chal1 " ;
			$params[':chal1']= trim($parts[0]);
		break;
		case "Challenge2":
		case "11":
			$extrasql .= "  ".$fldpre."`Challenge2`".$fldpost." >= :chal2 " ;
			$params[':chal2']= trim($parts[0]);
		break;
		case "Challenge3":
		case "12":
			$extrasql .= "  ".$fldpre."`Challenge3`".$fldpost." >= :chal3 " ;
			$params[':chal3']= trim($parts[0]);
		break;
		case "Challenge4":
		case "13":
			$extrasql .= "  ".$fldpre."`Challenge4`".$fldpost." >= :chal4 " ;
			$params[':chal4']= trim($parts[0]);
		break;
		case "Challenge5":
		case "14":
			$extrasql .= "  ".$fldpre."`Challenge5`".$fldpost." >= :chal5 " ;
			$params[':chal5']= trim($parts[0]);
		break;
	
	}

//debugging can be done by uncommenting this
//$debug=''.$extrasql." ".print_r($parts,true);
	
	$imagetosendback = "";
  	$query = $con->query('SELECT `username` FROM `playerdata` where `username`= :uuid '.$extrasql."", $params);
	$data = $query->fetchAll();
	$found=false;
	foreach($data as $item) {
		$found=true;
		$imagetosendback = $parts[7];
	}

	if($found === true){
	return($imagetosendback);
	}else{
	return ("nothing");
	}

}
    
function setUserSettings($con, $uid, $setting, $value){
	$query = $con->query(' INSERT INTO playersettings (player_id, setting, value, timestamp) VALUES (:plid, :setting, :value, now()) on duplicate key update value=:value, timestamp=now()',array(':plid'=>$uid, ':setting'=>$setting, ':value'=>$value));
}

function challengeSystemFindStatus($uid){
	$con = \Drupal\Core\Database\Database::getConnection('default');

	$query = $con->query('SELECT `Message` FROM `ChallengeStatusLog` WHERE `UserID` =:plid AND `DateAndTime` > now() - interval 1 minute LIMIT 1', array(':plid'=>$uid));
	$data = $query->fetchAll();

	$message = "";
	foreach($data as $item) {
		$message = $item->Message;
	}
	return($message);

}

function getUserSettings($con, $uid){
	$query = $con->query('SELECT * FROM playersettings where player_id=:plid', array(':plid'=>$uid));
	$data = $query->fetchAll();
	$ret=array();
	foreach($data as $item) {
		$ret[$item->setting] = $item->value;
	}
	return($ret);
}

function checkChallengeCompleted($con,$uuid,$sim,$parts){
	$params=array(':uuid' => $uuid);
	$extrasql = "";
	if (!is_array($parts)) $parts=array();
	$parts= array_pad($parts,7,'');
  	
	$parts[3] = str_replace("\n", "", $parts[3]);
	$parts[3] = str_replace("\r", "", $parts[3]);
	if ((trim($parts[3])=="sim")||(trim($parts[3])==6)){
		if (trim($parts[2])!=""){
			$extrasql .= " and `sim` = :sim " ;
			$params[':sim']= trim($parts[2]);		
		}
	}

	$parts[6] = str_replace("\n", "", $parts[6]);
	$parts[6] = str_replace("\r", "", $parts[6]);
	switch(trim($parts[6])){
		case "total":
		case "16":
			$fldpre="group by `username` having sum(";
			$fldpost=") ";
		break;
		default:
			$fldpre=' and ';
			$fldpost='';
		break;
	}
	//$output.=print_r($parts,true);
	switch(trim($parts[1])){
		case "score":
		case "5":
			$extrasql .= " ".$fldpre."`score`".$fldpost." >= :score " ;
			$params[':score']= trim($parts[0]);
		break;
		case "Challenge1":
		case "10":
			$extrasql .= " ".$fldpre."`Challenge1`".$fldpost." >= :chal1 " ;
			$params[':chal1']= trim($parts[0]);
		break;
		case "Challenge2":
		case "11":
			$extrasql .= "  ".$fldpre."`Challenge2`".$fldpost." >= :chal2 " ;
			$params[':chal2']= trim($parts[0]);
		break;
		case "Challenge3":
		case "12":
			$extrasql .= "  ".$fldpre."`Challenge3`".$fldpost." >= :chal3 " ;
			$params[':chal3']= trim($parts[0]);
		break;
		case "Challenge4":
		case "13":
			$extrasql .= "  ".$fldpre."`Challenge4`".$fldpost." >= :chal4 " ;
			$params[':chal4']= trim($parts[0]);
		break;
		case "Challenge5":
		case "14":
			$extrasql .= "  ".$fldpre."`Challenge5`".$fldpost." >= :chal5 " ;
			$params[':chal5']= trim($parts[0]);
		break;
	
	}

//debugging can be done by uncommenting this
//$debug=''.$extrasql." ".print_r($parts,true);

//file_put_contents("/kunden/homepages/34/d764919300/htdocs/www_ridesims_com_v3_composer/jameswible123456789.log",date("r").$debug."\r\n", FILE_APPEND);

	
  	$query = $con->query('SELECT `username` FROM `playerdata` where `username`= :uuid '.$extrasql."", $params);
	$data = $query->fetchAll();

	$found=false;
	foreach($data as $item) {
		$found=true;
	}
	return ($found);
}

